# {{ template_generated_info }}

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
{% for i in range(1, iperf3_clients_reno + iperf3_clients_prague + 1) %}
  - job_name: 'iperf-client{{ i }}'
    metrics_path: /probe
    static_configs:
      - targets: # iperf3 servers
        - 172.20.2.{{ 10 + i }}
    params:
      port: ['5201']
      # Optional: enable reverse mode
      # reverse_mode: ['true']
      # Half TCP and half UDP tests
      mode: ['tcp']
      # Optional: target bitrate in bits/sec (0 for unlimited)
      # (default 1 Mbit/sec for UDP, unlimited for TCP)
      bitrate: ['10K']
      # Optional: set test period
      # period: ['10s']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 172.20.1.{{ 10 + i }}:9579  # iperf3 client
{% endfor %}
